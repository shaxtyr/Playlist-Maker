<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mediaFragment">

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.practicum.playlistmaker.setting.ui.SettingsFragment"
        android:label="SettingsFragment" />
    <fragment
        android:id="@+id/searchTrackFragment"
        android:name="com.practicum.playlistmaker.search.ui.SearchTrackFragment"
        android:label="SearchTrackFragment" >
        <action
            android:id="@+id/action_searchTrackFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
    </fragment>
    <fragment
        android:id="@+id/mediaFragment"
        android:name="com.practicum.playlistmaker.media.ui.MediaFragment"
        android:label="MediaFragment" >
        <action
            android:id="@+id/action_mediaFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_mediaFragment_to_creatingPlaylistFragment"
            app:destination="@id/creatingPlaylistFragment" />
    </fragment>
    <fragment
        android:id="@+id/playerFragment"
        android:name="com.practicum.playlistmaker.player.ui.PlayerFragment"
        android:label="PlayerFragment" >
        <action
            android:id="@+id/action_playerFragment_to_creatingPlaylistFragment"
            app:destination="@id/creatingPlaylistFragment" />
    </fragment>
    <fragment
        android:id="@+id/creatingPlaylistFragment"
        android:name="com.practicum.playlistmaker.media.ui.fragment.CreatingPlaylistFragment"
        android:label="fragment_creating_playlist"
        tools:layout="@layout/fragment_creating_playlist" />
</navigation>
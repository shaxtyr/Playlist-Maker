<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    tools:context=".media.ui.fragment.PlaylistDetailsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@id/left_guideline_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="16dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/right_guideline_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="16dp" />

        <ImageButton
            android:id="@+id/backToMedia"
            style="@style/BackStyleSettingsScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/margin_16"
            android:layout_marginStart="@dimen/margin_16"
            android:background="@null"
            app:srcCompat="@drawable/ic_arrow_back_24" />

        <ImageView
            android:id="@id/playlistCover"
            android:layout_width="360dp"
            android:layout_height="360dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_gravity="center_horizontal"
            tools:src="@drawable/placeholder_312"
            android:visibility="visible"
            android:scaleType="center"/>

        <TextView
            android:id="@+id/playlistName"
            style="@style/PlaylistNameStylePlaylistDetailsScreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/playlistCover"
            app:layout_constraintStart_toStartOf="@id/left_guideline_16"
            app:layout_constraintEnd_toEndOf="@id/right_guideline_16"
            tools:text="@string/empty_my_playlists"/>

        <TextView
            android:id="@+id/playlistDescription"
            style="@style/PlaylistDescriptionStylePlaylistDetailsScreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/playlistName"
            app:layout_constraintStart_toStartOf="@id/left_guideline_16"
            app:layout_constraintEnd_toEndOf="@id/right_guideline_16"
            tools:text="@string/empty_my_playlists"/>

        <LinearLayout
            android:id="@+id/tracksInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@id/left_guideline_16"
            app:layout_constraintTop_toBottomOf="@id/playlistDescription"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tracksTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/PlaylistDescriptionStylePlaylistDetailsScreen"
                tools:text="@string/nothing_found"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_point_black_13"/>

            <TextView
                android:id="@+id/tracksNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/PlaylistDescriptionStylePlaylistDetailsScreen"
                tools:text="@string/nothing_found"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/shareTracks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="@id/left_guideline_16"
            app:layout_constraintTop_toBottomOf="@id/tracksInfo"
            android:layout_marginTop="@dimen/margin_16"
            android:src="@drawable/ic_share_black_24"/>

        <ImageView
            android:id="@+id/actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/shareTracks"
            app:layout_constraintTop_toBottomOf="@id/tracksInfo"
            android:layout_marginTop="@dimen/margin_16"
            android:layout_marginStart="@dimen/margin_16"
            android:src="@drawable/ic_vertical_ellipses_black_24"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/playlistDetailsBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        app:behavior_hideable="false"
        app:behavior_peekHeight="166dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior" >

        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounder" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
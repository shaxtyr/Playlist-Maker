<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSecondary"
        tools:layout="@layout/fragment_player"
        tools:theme="@style/Base.Theme.PlaylistMaker">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/left_guideline_16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="16dp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/left_guideline_24"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="24dp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/right_guideline_24"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="24dp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/right_guideline_16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="16dp" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/textsBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                app:barrierDirection="end"
                app:constraint_referenced_ids="duration_audio_player" />

            <ImageButton
                android:id="@+id/back_from_audio_player"
                style="@style/BackStyleSettingsScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@null"
                app:layout_constraintStart_toStartOf="@id/left_guideline_16"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_arrow_back_24" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cover_audio_player"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="42dp"
                android:backgroundTint="?attr/colorSecondary"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_24"
                app:layout_constraintStart_toStartOf="@id/left_guideline_24"
                app:layout_constraintTop_toBottomOf="@id/back_from_audio_player">

                <ImageView
                    android:id="@+id/cover_from_cardview"
                    android:layout_width="312dp"
                    android:layout_height="312dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    tools:src="@tools:sample/avatars" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/track_name_audio_player"
                style="@style/PlaceholderMessageStyleSearchScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="start"
                android:text="@string/nothing_found"
                android:textSize="22sp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_24"
                app:layout_constraintStart_toStartOf="@id/left_guideline_24"
                app:layout_constraintTop_toBottomOf="@id/cover_audio_player" />

            <TextView
                android:id="@+id/artist_name_audio_player"
                style="@style/PlaceholderMessageStyleSearchScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="start"
                android:text="@string/nothing_found"
                android:textSize="14sp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_24"
                app:layout_constraintStart_toStartOf="@id/left_guideline_24"
                app:layout_constraintTop_toBottomOf="@id/track_name_audio_player" />

            <ImageButton
                android:id="@+id/add_to_playlist_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="54dp"
                android:background="@null"
                android:src="@drawable/ic_add_to_playlist_51"
                app:layout_constraintEnd_toStartOf="@id/play_button"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toEndOf="@id/left_guideline_24"
                app:layout_constraintTop_toBottomOf="@id/artist_name_audio_player" />

            <com.practicum.playlistmaker.player.ui.PlaybackButtonView
                android:id="@+id/play_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/like_button"
                app:layout_constraintStart_toEndOf="@id/add_to_playlist_button"
                app:layout_constraintTop_toBottomOf="@id/artist_name_audio_player"
                app:imageResPlayId="@drawable/ic_play_100"
                app:imageResPauseId="@drawable/ic_pause_100"/>

            <ImageButton
                android:id="@+id/like_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:src="@drawable/ic_like_51"
                app:layout_constraintBottom_toBottomOf="@id/add_to_playlist_button"
                app:layout_constraintEnd_toEndOf="@id/right_guideline_24"
                app:layout_constraintStart_toEndOf="@id/play_button" />

            <TextView
                android:id="@+id/progress_bar_audio_player"
                style="@style/TextYouSearchedStyleSearchScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/progress"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/play_button" />

            <!--duration -->
            <TextView
                android:id="@+id/duration_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duration"
                android:textColor="@color/gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/textsBarrier"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/left_guideline_16"
                app:layout_constraintTop_toTopOf="@id/time_value_audio_player" />

            <TextView
                android:id="@+id/time_value_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="39dp"
                android:gravity="end"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_16"
                app:layout_constraintStart_toEndOf="@id/textsBarrier"
                app:layout_constraintTop_toBottomOf="@id/progress_bar_audio_player"
                tools:text="@string/nothing_found" />

            <!--albumGroup -->
            <androidx.constraintlayout.widget.Group
                android:id="@+id/albumGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="visible"
                app:constraint_referenced_ids="album_audio_player,album_value_audio_player" />

            <TextView
                android:id="@+id/album_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/album"
                android:textColor="@color/gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/textsBarrier"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/left_guideline_16"
                app:layout_constraintTop_toTopOf="@id/album_value_audio_player" />

            <TextView
                android:id="@+id/album_value_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:gravity="end"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_16"
                app:layout_constraintStart_toEndOf="@id/textsBarrier"
                app:layout_constraintTop_toBottomOf="@id/time_value_audio_player"
                tools:text="@string/nothing_found" />

            <!--yearGroup -->
            <androidx.constraintlayout.widget.Group
                android:id="@+id/yearGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="visible"
                app:constraint_referenced_ids="year_audio_player,year_value_audio_player" />

            <TextView
                android:id="@+id/year_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/year"
                android:textColor="@color/gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/textsBarrier"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/left_guideline_16"
                app:layout_constraintTop_toTopOf="@id/year_value_audio_player" />

            <TextView
                android:id="@+id/year_value_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:gravity="end"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_16"
                app:layout_constraintStart_toEndOf="@id/textsBarrier"
                app:layout_constraintTop_toBottomOf="@id/album_value_audio_player"
                tools:text="@string/nothing_found" />

            <!--genre -->
            <TextView
                android:id="@+id/genre_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/genre"
                android:textColor="@color/gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/textsBarrier"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/left_guideline_16"
                app:layout_constraintTop_toTopOf="@id/genre_value_audio_player" />

            <TextView
                android:id="@+id/genre_value_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:gravity="end"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_16"
                app:layout_constraintStart_toEndOf="@id/textsBarrier"
                app:layout_constraintTop_toBottomOf="@id/year_value_audio_player"
                tools:text="@string/nothing_found" />

            <!--country-->
            <TextView
                android:id="@+id/country_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/country"
                android:textColor="@color/gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/textsBarrier"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/left_guideline_16"
                app:layout_constraintTop_toTopOf="@id/country_value_audio_player" />

            <TextView
                android:id="@+id/country_value_audio_player"
                style="@style/TextStyleSettingsScreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:layout_marginBottom="20dp"
                android:gravity="end"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/right_guideline_16"
                app:layout_constraintStart_toEndOf="@id/textsBarrier"
                app:layout_constraintTop_toBottomOf="@id/genre_value_audio_player"
                tools:text="@string/nothing_found" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <View android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/playlists_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        app:behavior_hideable="true"
        app:behavior_peekHeight="505dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior" >

        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounder" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingTop="18dp"
            android:paddingBottom="12dp"
            android:layout_gravity="center"
            android:textAlignment="center"
            android:text="@string/add_to_playlist"
            style="@style/PlaceholderMessageStyleSearchScreen"/>

        <Button
            android:id="@+id/newPlaylistFromBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/new_playlist"
            style="@style/PlaceholderButtonStyleSearchScreen"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewPlaylistBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"/>


    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
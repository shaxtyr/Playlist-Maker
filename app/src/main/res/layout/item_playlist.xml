<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="@dimen/margin_16"
    android:background="@null"
    card_view:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent" >

        <ImageView
            android:id="@+id/playlistCover"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            card_view:layout_constraintStart_toStartOf="parent"
            card_view:layout_constraintEnd_toEndOf="parent"
            card_view:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/rectangle_160"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:scaleType="center"
            tools:src="@tools:sample/avatars"/>

        <TextView
            android:id="@+id/playlistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            card_view:layout_constraintTop_toBottomOf="@id/playlistCover"
            card_view:layout_constraintStart_toStartOf="@id/playlistCover"
            style="@style/TextPlaylistScreen"
            tools:text="@string/nothing_found"/>

        <TextView
            android:id="@+id/numberOfTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            card_view:layout_constraintTop_toBottomOf="@id/playlistName"
            card_view:layout_constraintStart_toStartOf="@id/playlistName"
            style="@style/TextPlaylistScreen"
            tools:text="@string/nothing_found"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>